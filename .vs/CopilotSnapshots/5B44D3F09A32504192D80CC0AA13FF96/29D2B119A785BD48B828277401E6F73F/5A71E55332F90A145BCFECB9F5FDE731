    private static string FriendlyError(Exception ex) => ex switch
    {
        TaskCanceledException or OperationCanceledException
            => "Receiver did not respond (timed out). Verify the IP address is correct.",
        HttpRequestException httpEx when httpEx.InnerException is System.Net.Sockets.SocketException
            => $"Cannot reach receiver — {httpEx.InnerException.Message}",
        HttpRequestException httpEx
            => $"HTTP error — {httpEx.Message}",
        _ => ex.Message
    };

