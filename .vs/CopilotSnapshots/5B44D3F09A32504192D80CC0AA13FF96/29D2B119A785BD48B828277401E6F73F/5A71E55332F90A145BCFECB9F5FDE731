    private async void OpenPandora_Click(object sender, RoutedEventArgs e)
    {
        if (_client is null)
        {
            LastStatusText.Text = "Connect first.";
            return;
        }

        try
        {
            LastStatusText.Text = "Switching to Online Music...";
            await _client.SendZoneCommandAsync(MainZoneNameTextBox.Text.Trim(), "PutZone_InputFunction/NET");
            await Task.Delay(1500);

            LastStatusText.Text = "Selecting Pandora...";
            await _client.SendNetAudioCommandAsync("PutNetAudioCommand/PANDORA");
            await Task.Delay(1000);

            // PANDORA command highlights Pandora in the top-level menu but doesn't enter it.
            // Send CurEnter to open Pandora.
            await _client.SendNetAudioCommandAsync("PutNetAudioCommand/CurEnter");
            LastStatusText.Text = "Entering Pandora... loading stations...";

            // Poll until the receiver enters Pandora (ListLayer changes or NetFunction becomes Pandora).
            bool navigatedBackFromNowPlaying = false;
            for (int attempt = 0; attempt < 15; attempt++)
            {
                await Task.Delay(2000);
                NetAudioMenu menu = await _client.GetNetAudioMenuAsync();

                bool enteredPandora = menu.ListLayer > 0
                    || string.Equals(menu.NetFunction, "Pandora", StringComparison.OrdinalIgnoreCase);

                if (!enteredPandora)
                {
                    LastStatusText.Text = $"Waiting for Pandora to load... ({attempt + 1}/15)";
                    continue;
                }

                // Detect "Now Playing" mode: the receiver auto-plays the last station
                // and shows a playback screen with very few items (typically 1: "Now Playing").
                // We need to navigate back (CurLeft) to reach the station list.
                bool isNowPlaying = menu.TotalLines <= 1
                    || menu.MenuLines.Any(l => l.IndexOf("Now Playing", StringComparison.OrdinalIgnoreCase) >= 0);

                if (isNowPlaying && !navigatedBackFromNowPlaying)
                {
                    navigatedBackFromNowPlaying = true;
                    LastStatusText.Text = "Pandora is playing — navigating to station list...";
                    await _client.SendNetAudioCommandAsync("PutNetAudioCommand/CurLeft");
                    await Task.Delay(2000);
                    continue;
                }

                // We have a real station list (more than just "Now Playing").
                if (menu.MenuLines.Count > 0 && (menu.TotalLines > 1 || navigatedBackFromNowPlaying))
                {
                    _pandoraCursorLine = menu.CursorLine;
                    PandoraStationListBox.ItemsSource = menu.MenuLines;

                    if (menu.CursorLine > 0 && menu.CursorLine <= menu.MenuLines.Count)
                    {
                        PandoraStationListBox.SelectedIndex = menu.CursorLine - 1;
                    }
                    else
                    {
                        PandoraStationListBox.SelectedIndex = 0;
                    }

                    int total = menu.TotalLines > 0 ? menu.TotalLines : menu.MenuLines.Count;
                    LastStatusText.Text = $"Pandora — {total} station(s) loaded.";
                    await RefreshStatusAsync(showSuccessMessage: false);
                    return;
                }

                LastStatusText.Text = $"Waiting for station list... ({attempt + 1}/15)";
            }

            // Fallback: show whatever the menu currently contains.
            await LoadPandoraMenuAsync();
            await RefreshStatusAsync(showSuccessMessage: false);
        }
        catch (Exception ex)
        {
            LastStatusText.Text = $"Open Pandora failed: {FriendlyError(ex)}";
        }
    }

    private async void RefreshPandoraList_Click(object sender, RoutedEventArgs e)
    {
        if (_client is null)
