    private void InputKnob_MouseMove(object sender, MouseEventArgs e)
    {
        if (!_isInputKnobDragging)
        {
            return;
        }

        double currentAngle = GetKnobAngle(e.GetPosition(InputKnobHitArea), InputKnobHitArea);
        double delta = NormalizeAngleDelta(currentAngle - _lastInputKnobDragAngle);
        _lastInputKnobDragAngle = currentAngle;
        _inputKnobDragAccumulator += delta;

        const double stepThreshold = 14.0;
        while (Math.Abs(_inputKnobDragAccumulator) >= stepThreshold)
        {
            int direction = Math.Sign(_inputKnobDragAccumulator);
            _inputKnobDragAccumulator -= direction * stepThreshold;
            QueueInputStep(direction);
        }
    }

