    private async Task PlaySelectedPandoraStationAsync()
    {
        if (_client is null)
        {
            LastStatusText.Text = "Connect first.";
            return;
        }

        int selectedIndex = PandoraStationListBox.SelectedIndex;
        if (selectedIndex < 0)
        {
            LastStatusText.Text = "Select a station first.";
            return;
        }

        try
        {
            int targetLine = selectedIndex + 1;
            int delta = targetLine - _pandoraCursorLine;

            if (delta != 0)
            {
                string direction = delta > 0 ? "CurDown" : "CurUp";
                for (int i = 0; i < Math.Abs(delta); i++)
                {
                    await _client.SendNetAudioCommandAsync($"PutNetAudioCommand/{direction}");
                    await Task.Delay(100);
                }
            }

            await _client.SendNetAudioCommandAsync("PutNetAudioCommand/CurEnter");
            string stationName = PandoraStationListBox.SelectedItem?.ToString() ?? "station";
            LastStatusText.Text = $"Playing: {stationName}";
            _pandoraCursorLine = targetLine;
            await Task.Delay(1500);
            await RefreshStatusAsync(showSuccessMessage: false);
        }
        catch (Exception ex)
        {
            LastStatusText.Text = $"Play station failed: {FriendlyError(ex)}";
        }
    }

