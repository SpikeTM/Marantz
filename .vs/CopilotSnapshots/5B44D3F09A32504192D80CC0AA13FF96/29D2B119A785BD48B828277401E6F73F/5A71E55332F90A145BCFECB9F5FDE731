            // If we're on the "Now Playing" screen, navigate back to the station list first.
            bool isNowPlaying = menu.TotalLines <= 1
                || menu.MenuLines.Any(l => l.IndexOf("Now Playing", StringComparison.OrdinalIgnoreCase) >= 0);

            if (isNowPlaying && (menu.ListLayer > 0
                || string.Equals(menu.NetFunction, "Pandora", StringComparison.OrdinalIgnoreCase)))
