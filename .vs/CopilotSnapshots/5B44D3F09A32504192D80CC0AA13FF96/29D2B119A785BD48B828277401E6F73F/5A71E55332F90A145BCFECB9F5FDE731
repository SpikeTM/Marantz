    private async void SaveProfileButton_Click(object sender, RoutedEventArgs e)
    {
        string profileName = ProfileComboBox.Text.Trim();
        if (string.IsNullOrWhiteSpace(profileName))
        {
            LastStatusText.Text = "Profile name is required.";
            return;
        }

        ReceiverProfile profile = _profiles.FirstOrDefault(p => string.Equals(p.Name, profileName, StringComparison.OrdinalIgnoreCase))
            ?? new ReceiverProfile { Name = profileName };

        profile.IpAddress = ReceiverIpTextBox.Text.Trim();
        profile.MainZoneName = MainZoneNameTextBox.Text.Trim();
        profile.Zone2Name = Zone2NameTextBox.Text.Trim();

        if (_profiles.All(p => !string.Equals(p.Name, profile.Name, StringComparison.OrdinalIgnoreCase)))
        {
            _profiles.Add(profile);
        }

        await _profileStore.SaveProfilesAsync(_profiles);
        await LoadProfilesAsync(selectName: profile.Name);
        LastStatusText.Text = "Profile saved.";
    }

    private async void DeleteProfileButton_Click(object sender, RoutedEventArgs e)
    {
        if (ProfileComboBox.SelectedItem is not ReceiverProfile profile)
        {
            LastStatusText.Text = "Select a profile to delete.";
            return;
        }

        _profiles.RemoveAll(p => string.Equals(p.Name, profile.Name, StringComparison.OrdinalIgnoreCase));
        await _profileStore.SaveProfilesAsync(_profiles);
        await LoadProfilesAsync();
        LastStatusText.Text = "Profile deleted.";
    }

    private async Task LoadProfilesAsync(string? selectName = null)
    {
        _isBootstrapping = true;
        try
        {
            _profiles.Clear();
            _profiles.AddRange(await _profileStore.LoadProfilesAsync());

            if (_profiles.Count == 0)
            {
                var setup = new ProfileSetupWindow
                {
                    Owner = this
                };

                bool? result = setup.ShowDialog();
                if (result == true && setup.Result is not null)
                {
                    _profiles.Add(setup.Result);
                    await _profileStore.SaveProfilesAsync(_profiles);
                }
            }

            ProfileComboBox.ItemsSource = null;
            ProfileComboBox.ItemsSource = _profiles;

            ReceiverProfile? selected = null;
            if (!string.IsNullOrWhiteSpace(selectName))
            {
                selected = _profiles.FirstOrDefault(p => string.Equals(p.Name, selectName, StringComparison.OrdinalIgnoreCase));
            }

            selected ??= _profiles.FirstOrDefault();
            ProfileComboBox.SelectedItem = selected;

            if (selected is not null)
            {
                ReceiverIpTextBox.Text = selected.IpAddress;
                MainZoneNameTextBox.Text = selected.MainZoneName;
                Zone2NameTextBox.Text = selected.Zone2Name;
                await ConnectAndSyncAsync();
            }
        }
        finally
        {
            _isBootstrapping = false;
        }
    }

    private async Task ConnectAndSyncAsync()
    {
        _client = new MarantzReceiverClient(ReceiverIpTextBox.Text.Trim());
