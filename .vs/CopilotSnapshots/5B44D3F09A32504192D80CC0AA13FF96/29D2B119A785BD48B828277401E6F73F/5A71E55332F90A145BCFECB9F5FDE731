    private async void ScanNetworkButton_Click(object sender, RoutedEventArgs e)
    {
        _isScanningNetwork = true;
        _pollTimer.Stop();
        try
        {
            ScanNetworkButton.IsEnabled = false;
            var progress = new Progress<string>(message => LastStatusText.Text = message);

            IReadOnlyList<DiscoveredReceiver> receivers = await _ssdpDiscoveryService.DiscoverMarantzReceiversAsync(
                TimeSpan.FromSeconds(8), progress);

            DiscoveredReceiverComboBox.ItemsSource = receivers;

            if (receivers.Count == 0)
            {
                LastStatusText.Text = "No Marantz/Denon receivers found. Ensure the receiver is powered on and connected to the same network.";
                return;
            }

            DiscoveredReceiverComboBox.SelectedIndex = 0;

            if (receivers.Count == 1)
            {
                await ApplyDiscoveredReceiverAsync(receivers[0]);
            }
            else
            {
                LastStatusText.Text = $"Found {receivers.Count} receiver(s). Select one and click 'Use Selected' to connect.";
            }
        }
        catch (Exception ex)
        {
            LastStatusText.Text = $"Network scan failed: {FriendlyError(ex)}";
        }
        finally
        {
            ScanNetworkButton.IsEnabled = true;
            _isScanningNetwork = false;
            if (AutoRefreshToggle.IsChecked == true)
            {
                _pollTimer.Start();
            }
        }
    }

