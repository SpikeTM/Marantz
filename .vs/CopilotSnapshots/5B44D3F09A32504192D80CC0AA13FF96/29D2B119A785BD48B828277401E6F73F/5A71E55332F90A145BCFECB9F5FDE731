    private async Task LoadPandoraMenuAsync()
    {
        if (_client is null)
        {
            LastStatusText.Text = "Connect first.";
            return;
        }

        try
        {
            NetAudioMenu menu = await _client.GetNetAudioMenuAsync();
            _pandoraCursorLine = menu.CursorLine;

            PandoraStationListBox.ItemsSource = menu.MenuLines;

            if (menu.MenuLines.Count > 0 && menu.CursorLine > 0 && menu.CursorLine <= menu.MenuLines.Count)
            {
                PandoraStationListBox.SelectedIndex = menu.CursorLine - 1;
            }
            else if (menu.MenuLines.Count > 0)
            {
                PandoraStationListBox.SelectedIndex = 0;
            }

            string funcLabel = string.IsNullOrWhiteSpace(menu.NetFunction) ? "Net Audio" : menu.NetFunction;
            string statusLabel = string.IsNullOrWhiteSpace(menu.PlaybackStatus) ? "" : $" [{menu.PlaybackStatus}]";
            int total = menu.TotalLines > 0 ? menu.TotalLines : menu.MenuLines.Count;

            if (menu.ListLayer == 0 && menu.MenuLines.Count > 0)
            {
                LastStatusText.Text = $"{funcLabel}{statusLabel} — showing top-level menu (not inside Pandora). Try 'Open Pandora' again.";
            }
            else
            {
                LastStatusText.Text = $"{funcLabel}{statusLabel} — {total} item(s), layer {menu.ListLayer}.";
            }
        }
        catch (Exception ex)
        {
            LastStatusText.Text = $"Load menu failed: {FriendlyError(ex)}";
        }
    }
