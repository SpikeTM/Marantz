    private async void KnobCommandTimer_Tick(object? sender, EventArgs e)
    {
        if (_knobTickInProgress)
        {
            return;
        }

        if (_pendingVolumeSteps == 0 && _pendingInputCommands.Count == 0)
        {
            _knobCommandTimer.Stop();
            return;
        }

        _knobTickInProgress = true;
        try
        {
            if (_pendingVolumeSteps != 0)
            {
                int direction = Math.Sign(_pendingVolumeSteps);
                _pendingVolumeSteps -= direction;
                await StepVolumeKnobAsync(direction);
            }

            if (_pendingInputCommands.Count > 0)
            {
                CommandOption command = _pendingInputCommands.Dequeue();
                await SendMainCommandNoRefreshAsync($"PutZone_InputFunction/{command.Code}", $"Source set to {command.Label}.");
            }
        }
        finally
        {
            _knobTickInProgress = false;
        }
    }

    private async void KnobRefreshTimer_Tick(object? sender, EventArgs e)
    {
        if (_pendingVolumeSteps != 0 || _pendingInputCommands.Count != 0)
