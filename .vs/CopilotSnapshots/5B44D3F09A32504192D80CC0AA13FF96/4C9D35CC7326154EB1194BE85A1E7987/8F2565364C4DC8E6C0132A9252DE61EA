    private void InputKnob_MouseLeftButtonDown(object sender, MouseButtonEventArgs e)
    {
        _isInputKnobDragging = true;
        _lastInputKnobDragAngle = GetKnobAngle(e.GetPosition(InputKnobHitArea), InputKnobHitArea);
        _inputKnobDragAccumulator = 0.0;
