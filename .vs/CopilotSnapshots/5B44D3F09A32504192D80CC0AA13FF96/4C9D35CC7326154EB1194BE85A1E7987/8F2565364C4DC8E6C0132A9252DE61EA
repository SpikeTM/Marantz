            }
        }
        catch (Exception ex)
        {
            LastStatusText.Text = $"Refresh failed: {ex.Message}";
        }
    }

    private void RenderStatus(MainZoneStatus main, MainZoneStatus zone2, NetAudioStatus net)
    {
        ZoneText.Text = string.IsNullOrWhiteSpace(main.ZoneName) ? "MAIN ZONE" : main.ZoneName;
        PowerText.Text = main.ZonePower;
        InputText.Text = main.InputSource;
        VolumeText.Text = $"{main.Volume} | Mute: {main.MuteState}";
        Zone2StatusText.Text = $"{zone2.ZoneName} | {zone2.ZonePower} | {zone2.InputSource} | Vol {zone2.Volume} | Mute: {zone2.MuteState}";
        NowPlayingText.Text = string.IsNullOrWhiteSpace(net.NowPlaying)
            ? "No active stream"
            : net.NowPlaying;

        SyncInputKnobToStatus(main.InputSource);
        SyncVolumeKnobToStatus(main.Volume);
        UpdateKnobVisuals(animate: true);
    }

    private static void AnimateKnobAngle(RotateTransform? transform, double angle, bool animate)
    {
        if (transform is null)
        {
            return;
        }

        if (!animate)
        {
            transform.Angle = angle;
            return;
        }

        var easing = new CubicEase { EasingMode = EasingMode.EaseOut };
        var animation = new DoubleAnimation
        {
            To = angle,
            Duration = TimeSpan.FromMilliseconds(95),
            EasingFunction = easing
        };
        transform.BeginAnimation(RotateTransform.AngleProperty, animation);
    }

    private void UpdateKnobVisuals(bool animate)
    {
        AnimateKnobAngle(InputKnobRotate, _inputKnobAngle, animate);
        AnimateKnobAngle(InputKnobIndicatorRotate, _inputKnobAngle, animate);
        AnimateKnobAngle(VolumeKnobRotate, _volumeKnobAngle, animate);
        AnimateKnobAngle(VolumeKnobIndicatorRotate, _volumeKnobAngle, animate);
    }

    private static string NormalizeSourceName(string value)
    {
        return new string(value
            .ToUpperInvariant()
            .Where(char.IsLetterOrDigit)
            .ToArray());
    }

    private int FindInputIndex(string sourceName)
    {
        if (string.IsNullOrWhiteSpace(sourceName))
        {
            return -1;
        }

        string normalized = NormalizeSourceName(sourceName);
        List<CommandOption> options = GetInputOptions();

        for (int i = 0; i < options.Count; i++)
        {
            string code = NormalizeSourceName(options[i].Code ?? string.Empty);
            string label = NormalizeSourceName(options[i].Label ?? string.Empty);

            if (normalized == code || normalized == label || normalized.Contains(code) || normalized.Contains(label))
            {
                return i;
            }
        }

        return -1;
    }

    private List<CommandOption> GetInputOptions()
    {
        if (DiscoveredSourceComboBox.ItemsSource is IEnumerable<CommandOption> discovered)
        {
            List<CommandOption> values = discovered
                .Where(s => !string.IsNullOrWhiteSpace(s.Code))
                .ToList();

            if (values.Count > 0)
            {
                return values;
            }
        }

        return _defaultInputOptions;
    }

    private static double MapInputIndexToAngle(int index, int count)
    {
        if (count <= 1)
        {
            return 0;
        }

        double ratio = (double)index / (count - 1);
        return -140 + (ratio * 280);
    }

    private void SyncInputKnobToStatus(string inputSource)
    {
        int index = FindInputIndex(inputSource);
        List<CommandOption> options = GetInputOptions();

        if (index >= 0)
        {
            _currentInputIndex = index;
            _inputKnobAngle = MapInputIndexToAngle(index, options.Count);
        }
    }

    private void SyncVolumeKnobToStatus(string volume)
    {
        if (!double.TryParse(volume, out double numericVolume))
        {
            return;
        }

        double clamped = Math.Clamp(numericVolume, -80, 18);
        double ratio = (clamped + 80) / 98;
        _volumeKnobAngle = -140 + (ratio * 280);
    }

    private static double GetKnobAngle(Point point, FrameworkElement element)
    {
        double centerX = element.ActualWidth / 2.0;
        double centerY = element.ActualHeight / 2.0;
        return Math.Atan2(point.Y - centerY, point.X - centerX) * 180.0 / Math.PI;
    }

    private static double NormalizeAngleDelta(double delta)
    {
        while (delta > 180)
        {
            delta -= 360;
        }

        while (delta < -180)
        {
            delta += 360;
        }

        return delta;
    }

    private void ScheduleKnobRefresh()
    {
        _knobRefreshTimer.Stop();
        _knobRefreshTimer.Start();
    }

    private async Task SendMainCommandNoRefreshAsync(string command, string successMessage)
    {
        if (_client is null)
        {
            LastStatusText.Text = "Connect first.";
            return;
        }

        try
        {
            await _client.SendZoneCommandAsync(MainZoneNameTextBox.Text.Trim(), command);
            LastStatusText.Text = successMessage;
            ScheduleKnobRefresh();
        }
        catch (Exception ex)
        {
            LastStatusText.Text = $"Command failed: {ex.Message}";
        }
    }

    private void QueueVolumeStep(int direction)
    {
        if (direction == 0)
        {
            return;
        }

        _pendingVolumeSteps = Math.Clamp(_pendingVolumeSteps + direction, -64, 64);
        _volumeKnobAngle = Math.Clamp(_volumeKnobAngle + (direction * 8), -150, 150);
        UpdateKnobVisuals(animate: true);

        if (!_knobCommandTimer.IsEnabled)
        {
            _knobCommandTimer.Start();
        }
    }

    private void QueueInputStep(int direction)
    {
        if (direction == 0)
        {
            return;
        }

        List<CommandOption> options = GetInputOptions();
        if (options.Count == 0)
        {
            return;
        }

        if (_currentInputIndex < 0 || _currentInputIndex >= options.Count)
        {
            _currentInputIndex = FindInputIndex(InputText.Text);
            if (_currentInputIndex < 0)
            {
                _currentInputIndex = 0;
            }
        }

        int next = (_currentInputIndex + direction + options.Count) % options.Count;
        CommandOption selected = options[next];
        _currentInputIndex = next;
        _inputKnobAngle = MapInputIndexToAngle(next, options.Count);
        _pendingInputCommands.Enqueue(selected);
        UpdateKnobVisuals(animate: true);

        if (!_knobCommandTimer.IsEnabled)
        {
            _knobCommandTimer.Start();
        }
    }

    private async Task StepVolumeKnobAsync(int direction)
    {
        if (direction == 0)
        {
            return;
        }

        await SendMainCommandNoRefreshAsync(direction > 0 ? "PutMasterVolumeBtn/>" : "PutMasterVolumeBtn/<",
            direction > 0 ? "Volume up sent." : "Volume down sent.");
    }

    private void VolumeKnob_MouseWheel(object sender, MouseWheelEventArgs e)
    {
        QueueVolumeStep(e.Delta >= 0 ? 1 : -1);
    }

    private void VolumeKnob_MouseLeftButtonDown(object sender, MouseButtonEventArgs e)
    {
        _isVolumeKnobDragging = true;
        _lastVolumeKnobDragAngle = GetKnobAngle(e.GetPosition(VolumeKnobHitArea), VolumeKnobHitArea);
        _volumeKnobDragAccumulator = 0.0;
        VolumeKnobHitArea.CaptureMouse();
    }

    private void VolumeKnob_MouseMove(object sender, MouseEventArgs e)
    {
        if (!_isVolumeKnobDragging)
        {
            return;
        }

        double currentAngle = GetKnobAngle(e.GetPosition(VolumeKnobHitArea), VolumeKnobHitArea);
        double delta = NormalizeAngleDelta(currentAngle - _lastVolumeKnobDragAngle);
        _lastVolumeKnobDragAngle = currentAngle;
        _volumeKnobDragAccumulator += delta;

        const double stepThreshold = 11.0;
        while (Math.Abs(_volumeKnobDragAccumulator) >= stepThreshold)
        {
            int direction = Math.Sign(_volumeKnobDragAccumulator);
            _volumeKnobDragAccumulator -= direction * stepThreshold;
            QueueVolumeStep(direction);
        }
    }

    private void VolumeKnob_MouseLeftButtonUp(object sender, MouseButtonEventArgs e)
    {
        _isVolumeKnobDragging = false;
        VolumeKnobHitArea.ReleaseMouseCapture();
    }

    private void VolumeKnob_MouseLeave(object sender, MouseEventArgs e)
    {
        if (!_isVolumeKnobDragging)
        {
            return;
        }

        _isVolumeKnobDragging = false;
        VolumeKnobHitArea.ReleaseMouseCapture();
    }

    private void InputKnob_MouseWheel(object sender, MouseWheelEventArgs e)
