    private async Task RefreshStatusAsync(bool showSuccessMessage = true)
    {
        if (_client is null)
        {
            LastStatusText.Text = "Enter receiver IP and click Connect.";
            return;
        }

        try
        {
            MainZoneStatus main = await _client.GetZoneStatusAsync(MainZoneNameTextBox.Text.Trim());
            MainZoneStatus zone2 = await _client.GetZoneStatusAsync(Zone2NameTextBox.Text.Trim());
            NetAudioStatus net = await _client.GetNetAudioStatusAsync();
